# ───────── App ─────────
NODE_ENV=development
PORT=3000

# ───────── Database (MySQL บน Host Atom / Plesk) ─────────
# รูปแบบ: mysql://USER:PASSWORD@HOST:PORT/DBNAME
# ⚠️ ถ้ารหัสผ่านมีอักขระพิเศษ ต้อง URL-encode: @ → %40, # → %23, / → %2F
DATABASE_URL="mysql://farmland_user:CHANGE_ME@localhost:3306/farmland"
# shadow DB สำหรับ `prisma migrate dev` (สร้าง DB ว่างอีกตัวบน host แล้วชี้มาที่นี่)
SHADOW_DATABASE_URL="mysql://shadow_user:CHANGE_ME@localhost:3306/shadow_farmland"

# ───────── Email (Host Atom SMTP) ─────────
# ใช้อีเมลของโดเมนตัวเอง — host/port ดูได้ใน Plesk → Mail Settings
SMTP_HOST=thsv35.hostatom.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=bot01@family-sivarom.com
EMAIL_PASS=your-email-password
MAIL_FROM="ระบบปูคอนโด <bot01@family-sivarom.com>"
# MAIL_TO = ปลายทาง fallback เท่านั้น — ปกติส่งหา email ของ user เจ้าของระบบ (ตาราง User)
MAIL_TO=jame.piyawat111@gmail.com

# ───────── Scheduler ─────────
# secret สำหรับป้องกัน endpoint /api/scheduler/tick (Plesk Scheduled Task จะแนบ header นี้มา)
SCHEDULER_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# ตอน dev ในเครื่อง: true = ให้ node-cron ในแอปยิง tick เองทุก 15 นาที (บน production ปิดไว้ แล้วใช้ Plesk Scheduled Task แทน)
ENABLE_INTERNAL_CRON=true

# ───────── Auth (JWT access + refresh) ─────────
# สุ่ม secret ยาวๆ: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
FRONTEND_URL=http://localhost:5173

# ───────── Cloudinary (รูปประวัติพัฒนาการปู) ─────────
# ดูค่าได้ที่ Cloudinary Dashboard → Product Environment Credentials
# ถ้าเว้นว่าง: endpoint อัปโหลดรูป (/api/uploads/crab-image) จะตอบ 503
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
